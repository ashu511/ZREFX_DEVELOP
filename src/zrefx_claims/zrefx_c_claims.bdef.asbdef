projection;
strict ( 2 );
use draft;
define behavior for ZREFX_C_CLAIMS //alias <alias_name>
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;
  use association _Attachments { create; with draft; }
}
define behavior for ZREFX_C_ATT_CLAIMS
{
  use update;
  use delete;
  //  use action upload;
  //  use action delete;
  //  use action download;
  use association _claims { with draft; }

}