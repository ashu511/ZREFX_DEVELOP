managed implementation in class zbp_refx_i_row_request unique;
strict ( 2 );

define behavior for ZREFX_I_ROW_REQUEST //alias <alias_name>
persistent table zrefx_row
lock master
authorization master ( instance )
late numbering
//etag master <field_name>
{
  create ( authorization : global );
  update;
  delete;
  field ( readonly ) RequestId;
  field ( mandatory ) Statuscode;

  determination fetchRequestTypeBeforeSave on modify { create; }

  association _Clarifications { create; }
  association _LandAllocations { create; }
  association _Proposal { create; }
  association _RequestAttachments { create; }
  association _WorkflowInstance { create; }

  mapping for zrefx_row
    {
      RequestId                  = request_id;
      Actualcompletiondate       = actualcompletiondate;
      Additionalcomments         = additionalcomments;
      Approvalstatus             = approvalstatus;
      Approvalstatuscode         = approvalstatuscode;
      Areasqmrequested           = areasqmrequested;
      Businessarea               = businessarea;
      Businessjustification      = businessjustification;
      Cablelengthkm              = cablelengthkm;
      Capacitymva                = capacitymva;
      Companycode                = companycode;
      Costcenter                 = costcenter;
      Currentprocessorrole       = currentprocessorrole;
      Currentprocessoruser       = currentprocessoruser;
      Currentstep                = currentstep;
      Currentstepchangedat       = currentstepchangedat;
      Externalprojectaccountno   = externalprojectaccountno;
      Facilitytype               = facilitytype;
      Gislocationlink            = gislocationlink;
      Gisprojectid               = gisprojectid;
      Hijrienddate               = hijrienddate;
      Hijristartdate             = hijristartdate;
      Initiatedbyrole            = initiatedbyrole;
      Landcategory               = landcategory;
      Lengthmrequested           = lengthmrequested;
      Plancompletiondate         = plancompletiondate;
      Previousrequestno          = previousrequestno;
      Priority                   = priority;
      Profitcenter               = profitcenter;
      Projectapprovalyear        = projectapprovalyear;
      Projectbudgetyear          = projectbudgetyear;
      Projectcostsar             = projectcostsar;
      Projectenddate             = projectenddate;
      Projectname                = projectname;
      Projectstartdate           = projectstartdate;
      Requestdate                = requestdate;
      Requestdescription         = requestdescription;
      Requestor                  = requestor;
      Requestorcomments          = requestorcomments;
      Requestpurpose             = requestpurpose;
      Requesttype                = requesttype;
      Sourcedepartment           = sourcedepartment;
      Sourcesubsidiary           = sourcesubsidiary;
      Stagegateprojectno         = stagegateprojectno;
      Stationtype                = stationtype;
      Status                     = status;
      Statuscode                 = statuscode;
      Voltagekv                  = voltagekv;
      Wbsprojectno               = wbsprojectno;
      Widthmrequested            = widthmrequested;
      UserId                     = userid;
      UserName                   = username;
      Title                      = title;
      Department                 = department;
      CurrentStepDesc            = currentstepdescription;
      //      Projectname_A            = projectname_a;
      CurrentProcessorName       = currentprocessorname;
      CurrentProcessorDepartment = currentprocessordepartment;
      MileStoneDescription       = milestonedesc;
      Milestone                  = milestone;
      WorkflowInstanceId         = workflowinstanceid;
      MilestoneSequence          = milestonesequence;
    }


}

define behavior for ZREFX_I_ROW_CLARIFICATION //alias <alias_name>
persistent table zrefx_row_clarif
lock dependent by _ROWRequest
authorization dependent by _ROWRequest
late numbering
//etag master <field_name>
{
  update;
  delete;
  field ( readonly ) Id, RequestId;

  association _ROWRequest;

  mapping for zrefx_row_clarif
    {
      RequestId  = request_id;
      Answer     = answer;
      Answeredby = answeredby;
      Question   = question;
      Raisedby   = raisedby;
      Statuscode = statuscode;
      UserId     = userid;
      UserName   = username;
      Title      = title;
      Department = department;
      Id         = id;
    }
}

