define behavior for ZREFX_I_ROW_PROPOSEDLAND //alias <alias_name>
persistent table zrefx_row_propl
lock dependent by _LandRequest
authorization dependent by _LandRequest
late numbering
//etag master <field_name>
{
  update;
  delete;
  field ( readonly ) Id, ProposalId, RequestId;
  association _LandRequest;
  association _Proposal;
  association _SiteVisit { create; }
  association _SiteVisitNom { create; }
  mapping for zrefx_row_propl
    {
      Id                       = id;
      ProposalId               = proposalid;
      RequestId                = request_id;
      Landid                   = landid;
      City                     = city;
      District                 = district;
      Postalcode               = postalcode;
      Totalarea                = totalarea;
      Remainingarea            = remainingarea;
      Latitude                 = latitude;
      Longitude                = longitude;
      Gismaplink               = gismaplink;
      Divisionemployeeuserid   = divisionemployeeuserid;
      Divisionemployeefullname = divisionemployeefullname;
      Divisionemployeeremarks  = divisionemployeeremarks;
      Supportingdocuments      = supportingdocuments;
      IsFitsRequirement        = isfitsrequirement;
      IsSelectSiteVisit        = isselectsitevisit;
      Status                   = status;
    }
}

define behavior for ZREFX_I_ROW_SITEVISIT //alias <alias_name>
persistent table zrefx_row_sitevi
lock dependent by _LandRequest
authorization dependent by _LandRequest
late numbering
//etag master <field_name>
{
  update;
  delete;
  field ( readonly ) ID, ProposalId, ProposalLandId, RequestId;
  association _LandRequest;
  association _ProposedLand;
  association _Attachments { create; }
  mapping for zrefx_row_sitevi
    {
      ID                   = id;
      RequestId            = request_id;
      ProposalId           = proposalid;
      ProposalLandId       = proposalandid;
      Proposal             = proposal;
      Proposedland         = proposedland;
      Plannedvisitdatetime = plannedvisitdatetime;
      Actualvisitdatetime  = actualvisitdatetime;
      Engineer             = engineer;
      Statuscode           = statuscode;
      Status               = status;
      Reports              = reports;
      Widthmmeasured       = widthmmeasured;
      Lengthmmeasured      = lengthmmeasured;
      Areasqmmeasured      = areasqmmeasured;
      Obstacles            = obstacles;
      Safetyobservations   = safetyobservations;
      Sitenotes            = sitenotes;
      UserId               = userid;
      UserName             = username;
      Title                = title;
      Department           = department;
    }
}

