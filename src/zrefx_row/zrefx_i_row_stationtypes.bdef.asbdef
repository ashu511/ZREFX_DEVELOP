managed implementation in class zbp_refx_i_row_stationtypes unique;
strict ( 2 );

define behavior for ZREFX_I_ROW_STATIONTYPES //alias <alias_name>
persistent table zrefx_row_stypes
lock master
authorization master ( instance )
//etag master <field_name>
{
  create ( authorization : global );
  update;
  delete;
  field ( readonly, numbering : managed ) Id;
  mapping for zrefx_row_stypes
    {
      Id      = id;
      Code    = code;
      Text    = text;
    }
}